# BYB! Server Configuration
# Copy this file to .env and adjust values for your deployment

# Port the server listens on
BYB_PORT=3001

# Directory where budget.json, passwords.json, sessions.json are stored
# For TrueNAS SCALE: mount a persistent dataset here (e.g. /data)
BYB_DATA_DIR=./data

# Session lifetime in hours (default: 72)
BYB_SESSION_TTL_HOURS=72

# bcrypt hash rounds (12 recommended; higher = slower but more secure)
BYB_BCRYPT_ROUNDS=12
